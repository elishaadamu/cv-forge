generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id               String         @id @default(cuid())
  name             String?
  email            String?        @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             Role           @default(USER)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  otpCode          String?
  otpExpiry        DateTime?
  resetToken       String?        @unique
  resetTokenExpiry DateTime?
  accounts         Account[]
  cvs              CV[]
  sessions         Session[]
  comments         Comment[]
  atsAudits        AtsAudit[]
  aiGenerations    AiGeneration[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CV {
  id           String          @id @default(cuid())
  name         String          @default("Untitled CV")
  templateId   String          @default("modern")
  status       String          @default("DRAFT") // DRAFT, COMPLETED, DOWNLOADED
  userId       String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  educations   Education[]
  experiences  Experience[]
  personalInfo PersonalInfo?
  projects     Project[]
  skills       SkillCategory[]
  languages    Language[]
  volunteering Volunteering[]
}

model PersonalInfo {
  id           String  @id @default(cuid())
  fullName     String
  email        String
  phoneCode    String?
  phone        String?
  country      String?
  county       String?
  location     String?
  facebook     String?
  github       String?
  linkedin     String?
  website      String?
  jobTitle     String?
  summary      String?
  profileImage String?
  dateOfBirth  String?
  placeOfBirth String?
  nationality  String?
  gender       String?
  passport     String?
  workPermit   String?
  cvId         String  @unique
  cv           CV      @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Experience {
  id              String   @id @default(cuid())
  company         String
  role            String
  cvId            String
  duration        String
  location        String?
  description     String[] @default([])
  workDescription String?
  cv              CV       @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Education {
  id           String  @id @default(cuid())
  school       String
  degree       String
  cvId         String
  duration     String
  location     String?
  fieldOfStudy String?
  grade        String?
  cv           CV      @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model SkillCategory {
  id       String   @id @default(cuid())
  category String
  items    String[] @default([])
  cvId     String
  cv       CV       @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Project {
  id          String  @id @default(cuid())
  description String?
  link        String?
  cvId        String
  name        String
  cv          CV      @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Language {
  id          String @id @default(cuid())
  name        String
  proficiency String
  cvId        String
  cv          CV     @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Volunteering {
  id           String  @id @default(cuid())
  organization String
  role         String
  duration     String
  location     String?
  description  String? @db.Text
  cvId         String
  cv           CV      @relation(fields: [cvId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  blogSlug  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([blogSlug])
}

model AtsAudit {
  id             String   @id @default(cuid())
  userId         String
  jobDescription String?  @db.Text
  score          Int
  analysisData   String   @db.Text // JSON string of checks, suggestions, etc.
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiGeneration {
  id        String   @id @default(cuid())
  userId    String
  topic     String   @db.Text
  title     String
  excerpt   String   @db.Text
  content   String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
